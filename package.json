{
  "name": "miner-locator",
  "version": "0.2.2",
  "private": true,
  "description": "Miner-Finder with Electron packaging for Linux and Windows portable builds",
  "main": "electron-main.js",
  "scripts": {
    "start": "node server.js",
    "capture:snapshot": "node scripts/capture-scan-snapshot.js",
    "test:column-regression": "node scripts/run-column-regression.js",
    "electron:dev": "electron .",
    "build:electron": "electron-builder",
    "build:electron:linux": "electron-builder --linux AppImage",
    "build:electron:win": "electron-builder --win portable",
    "build:electron:all": "electron-builder --linux AppImage --win portable"
  },
  "dependencies": {
    "express": "^4.21.2"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.bensoluna.minerlocator",
    "productName": "Miner-Finder",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "dist/electron"
    },
    "asar": true,
    "files": [
      "electron-main.js",
      "server.js",
      "public/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Network"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "Miner-Finder-${version}-portable-win.exe"
    }
  }
}